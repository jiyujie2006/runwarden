{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["runwarden-proxy"],
  "model": "runwarden-proxy/big-pickle",
  "provider": {
    "runwarden-proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Runwarden Proxied LLM",
      "options": {
        "baseURL": "http://127.0.0.1:8787/v1",
        "apiKey": "{env:RUNWARDEN_PROXY_CLIENT_TOKEN}"
      },
      "models": {
        "big-pickle": {
          "name": "Runwarden-proxied (client capability from RUNWARDEN_PROXY_CLIENT_TOKEN; upstream key stays server-side)"
        }
      }
    }
  },
  "tools": {
    "*": false,
    "runwarden_*": true
  },
  "mcp": {
    "runwarden": {
      "type": "local",
      "command": ["runwarden-mcp"],
      "enabled": true
    }
  }
}
