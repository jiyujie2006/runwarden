{
  "client": "opencode",
  "config": "examples/agent-configs/opencode.runwarden-only.json",
  "claim": "OpenCode can only call Runwarden MCP tools, and a path traversal provider call is denied by Runwarden before side effects.",
  "request": {
    "jsonrpc": "2.0",
    "id": 2,
    "method": "tools/call",
    "params": {
      "name": "runwarden.provider.call",
      "arguments": {
        "provider": "external.mcp.filesystem.read_file",
        "action": "read_file",
        "path": "../../../../etc/passwd"
      }
    }
  },
  "response": {
    "jsonrpc": "2.0",
    "id": 2,
    "result": {
      "content": [
        {
          "type": "text",
          "text": "{\"decision\":\"denied\",\"error_kind\":\"root_escape\",\"execution_status\":\"not_executed\",\"side_effect_executed\":false,\"obs_ref\":\"obs_path_escape_denied\"}"
        }
      ],
      "isError": true
    }
  }
}
