{
  "client": "opencode",
  "config": "examples/agent-configs/opencode.runwarden-only.json",
  "claim": "OpenCode can only call Runwarden MCP tools, and a path traversal provider call is rejected by Rust typed-resource validation before an operation or side effect.",
  "request": {
    "jsonrpc": "2.0",
    "id": 2,
    "method": "tools/call",
    "params": {
      "name": "runwarden.provider.call",
      "arguments": {
        "provider": "external.mcp.filesystem.read_file",
        "path": "../../../../etc/passwd"
      }
    }
  },
  "response": {
    "jsonrpc": "2.0",
    "id": 2,
    "result": {
      "content": [
        {
          "type": "text",
          "text": "{\"error_kind\":\"resource_invalid\",\"operation_id\":null,\"reason_code\":\"resource_invalid\",\"side_effect_executed\":false}"
        }
      ],
      "isError": true
    }
  }
}
