{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TraceQuery",
  "type": "object",
  "required": [
    "limit",
    "offset"
  ],
  "properties": {
    "event_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "limit": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "max_bytes": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint",
      "minimum": 0.0
    },
    "obs_prefix": {
      "type": [
        "string",
        "null"
      ]
    },
    "offset": {
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "provider": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
