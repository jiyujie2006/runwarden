{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SecurityStory",
  "type": "object",
  "required": [
    "attack_category",
    "attack_content_hash",
    "authority",
    "enforcement_mode",
    "event_count",
    "evidence_status",
    "final_outcome_summary",
    "identity",
    "operations",
    "provenance",
    "report_claims",
    "run_mode",
    "safe_attack_preview",
    "scenario_id",
    "schema_version",
    "stage_statuses",
    "status",
    "story_id",
    "title"
  ],
  "properties": {
    "attack_category": {
      "type": "string"
    },
    "attack_content_hash": {
      "type": "string"
    },
    "authority": {
      "$ref": "#/definitions/AuthoritySnapshot"
    },
    "enforcement_mode": {
      "$ref": "#/definitions/EnforcementMode"
    },
    "event_count": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "evidence_status": {
      "$ref": "#/definitions/EvidenceStatus"
    },
    "final_event_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "final_outcome_summary": {
      "type": "string"
    },
    "identity": {
      "$ref": "#/definitions/StoryIdentity"
    },
    "operations": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/SecurityOperation"
      }
    },
    "provenance": {
      "$ref": "#/definitions/StoryProvenance"
    },
    "report_claims": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/StoryClaim"
      }
    },
    "run_mode": {
      "$ref": "#/definitions/RunMode"
    },
    "safe_attack_preview": {
      "type": "string"
    },
    "scenario_id": {
      "type": "string"
    },
    "schema_version": {
      "$ref": "#/definitions/SchemaVersion"
    },
    "stage_statuses": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/StoryStageStatus"
      }
    },
    "status": {
      "$ref": "#/definitions/StoryStatus"
    },
    "story_id": {
      "$ref": "#/definitions/StoryId"
    },
    "title": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "ApprovalId": {
      "type": "string",
      "format": "uuid",
      "maxLength": 36,
      "minLength": 36,
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
    },
    "ApprovalState": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "leased",
        "consumed",
        "denied",
        "expired",
        "revoked"
      ]
    },
    "ApprovalView": {
      "type": "object",
      "required": [
        "approval_id",
        "binding_digest",
        "state"
      ],
      "properties": {
        "approval_id": {
          "$ref": "#/definitions/ApprovalId"
        },
        "binding_digest": {
          "type": "string"
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "lease_id": {
          "anyOf": [
            {
              "$ref": "#/definitions/ExecutionLeaseId"
            },
            {
              "type": "null"
            }
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "reviewer": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "$ref": "#/definitions/ApprovalState"
        }
      },
      "additionalProperties": false
    },
    "ArtifactAuthority": {
      "type": "object",
      "required": [
        "allowed_formats",
        "path_prefix"
      ],
      "properties": {
        "allowed_formats": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "path_prefix": {
          "$ref": "#/definitions/WorkspaceRelativePath"
        }
      },
      "additionalProperties": false
    },
    "AuthoritySnapshot": {
      "type": "object",
      "required": [
        "actor_id",
        "allowed_providers",
        "artifacts",
        "authz_id",
        "authz_state",
        "budgets",
        "evidence",
        "expires_at",
        "files",
        "inputs",
        "networks",
        "policy_snapshot_hash",
        "session_id",
        "stores"
      ],
      "properties": {
        "actor_id": {
          "type": "string"
        },
        "allowed_providers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ArtifactAuthority"
          }
        },
        "authz_id": {
          "type": "string"
        },
        "authz_state": {
          "type": "string"
        },
        "budgets": {
          "$ref": "#/definitions/BudgetSnapshot"
        },
        "code": {
          "anyOf": [
            {
              "$ref": "#/definitions/CodeAuthority"
            },
            {
              "type": "null"
            }
          ]
        },
        "email": {
          "anyOf": [
            {
              "$ref": "#/definitions/EmailAuthority"
            },
            {
              "type": "null"
            }
          ]
        },
        "evidence": {
          "$ref": "#/definitions/EvidenceAuthority"
        },
        "expires_at": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/FileAuthority"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/InputAuthority"
          }
        },
        "networks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NetworkAuthority"
          }
        },
        "policy_snapshot_hash": {
          "type": "string"
        },
        "session_id": {
          "$ref": "#/definitions/SessionId"
        },
        "stores": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StoreAuthority"
          }
        }
      },
      "additionalProperties": false
    },
    "BudgetSnapshot": {
      "type": "object",
      "required": [
        "max_argument_bytes",
        "max_calls",
        "max_file_bytes",
        "max_model_calls",
        "max_model_input_bytes",
        "max_model_output_bytes",
        "max_network_bytes",
        "max_wall_time_ms"
      ],
      "properties": {
        "max_argument_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "max_calls": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "max_file_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "max_model_calls": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "max_model_input_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "max_model_output_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "max_network_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "max_wall_time_ms": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "CodeAuthority": {
      "type": "object",
      "required": [
        "allowed_runtimes",
        "maximum_limits",
        "network",
        "workspace"
      ],
      "properties": {
        "allowed_runtimes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maximum_limits": {
          "$ref": "#/definitions/ExecutionLimits"
        },
        "network": {
          "$ref": "#/definitions/NetworkCapability"
        },
        "workspace": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "DataClass": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ]
    },
    "EmailAuthority": {
      "type": "object",
      "required": [
        "allowed_recipients",
        "maximum_classification"
      ],
      "properties": {
        "allowed_recipients": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maximum_classification": {
          "$ref": "#/definitions/DataClass"
        }
      },
      "additionalProperties": false
    },
    "EnforcementMode": {
      "type": "string",
      "enum": [
        "monitor_only",
        "enforced"
      ]
    },
    "EvidenceAuthority": {
      "type": "object",
      "required": [
        "allowed_operations",
        "current_story_only"
      ],
      "properties": {
        "allowed_operations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/OperationId"
          }
        },
        "current_story_only": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "EvidenceStatus": {
      "type": "string",
      "enum": [
        "pending",
        "verified",
        "incomplete",
        "invalid"
      ]
    },
    "ExecutionLeaseId": {
      "type": "string",
      "format": "uuid",
      "maxLength": 36,
      "minLength": 36,
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
    },
    "ExecutionLimits": {
      "type": "object",
      "required": [
        "cpu_time_ms",
        "memory_bytes",
        "output_bytes",
        "process_count",
        "wall_time_ms"
      ],
      "properties": {
        "cpu_time_ms": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "memory_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "output_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "process_count": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "wall_time_ms": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "FileAccess": {
      "type": "string",
      "enum": [
        "read",
        "write"
      ]
    },
    "FileAuthority": {
      "type": "object",
      "required": [
        "access",
        "maximum_classification",
        "path_prefix",
        "root"
      ],
      "properties": {
        "access": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/FileAccess"
          }
        },
        "maximum_classification": {
          "$ref": "#/definitions/DataClass"
        },
        "path_prefix": {
          "type": "string"
        },
        "root": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "InputAuthority": {
      "type": "object",
      "required": [
        "allowed_sources",
        "maximum_classification"
      ],
      "properties": {
        "allowed_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maximum_classification": {
          "$ref": "#/definitions/DataClass"
        }
      },
      "additionalProperties": false
    },
    "MemoryAccess": {
      "type": "string",
      "enum": [
        "read",
        "write"
      ]
    },
    "NetworkAuthority": {
      "type": "object",
      "required": [
        "allowed_origins",
        "maximum_classification",
        "provider"
      ],
      "properties": {
        "allowed_origins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maximum_classification": {
          "$ref": "#/definitions/DataClass"
        },
        "provider": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "NetworkCapability": {
      "type": "string",
      "enum": [
        "none",
        "brokered"
      ]
    },
    "ObservationId": {
      "type": "string",
      "maxLength": 40,
      "minLength": 40,
      "pattern": "^obs_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
    },
    "OperationId": {
      "type": "string",
      "format": "uuid",
      "maxLength": 36,
      "minLength": 36,
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}(?![\\s\\S])"
    },
    "OperationState": {
      "type": "string",
      "enum": [
        "proposed",
        "policy_evaluated",
        "denied",
        "awaiting_approval",
        "denied_by_reviewer",
        "expired",
        "approved",
        "observed_only",
        "execution_leased",
        "executing",
        "completed",
        "failed",
        "outcome_unknown"
      ]
    },
    "PolicyCheck": {
      "type": "object",
      "required": [
        "check_id",
        "layer",
        "reason",
        "status"
      ],
      "properties": {
        "check_id": {
          "type": "string"
        },
        "layer": {
          "type": "string"
        },
        "observation_ref": {
          "anyOf": [
            {
              "$ref": "#/definitions/ObservationId"
            },
            {
              "type": "null"
            }
          ]
        },
        "reason": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/PolicyCheckStatus"
        }
      },
      "additionalProperties": false
    },
    "PolicyCheckStatus": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "requires_review",
        "not_evaluated"
      ]
    },
    "PolicyDecision": {
      "type": "string",
      "enum": [
        "allowed",
        "denied",
        "requires_review"
      ]
    },
    "ProviderExecutionStatus": {
      "type": "string",
      "enum": [
        "not_executed",
        "running",
        "completed",
        "failed_before_side_effect",
        "executed_with_error",
        "outcome_unknown",
        "simulated"
      ]
    },
    "ProviderResultView": {
      "type": "object",
      "required": [
        "execution_status",
        "output"
      ],
      "properties": {
        "error_kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "execution_status": {
          "$ref": "#/definitions/ProviderExecutionStatus"
        },
        "output": {
          "$ref": "#/definitions/SafeProviderOutput"
        },
        "output_hash": {
          "anyOf": [
            {
              "$ref": "#/definitions/Sha256Digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "reason_code": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "ReportClaimSupport": {
      "type": "object",
      "anyOf": [
        {
          "type": "object",
          "required": [
            "provider"
          ],
          "properties": {
            "provider": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "event_kind"
          ],
          "properties": {
            "event_kind": {
              "$ref": "#/definitions/StoryEventKind"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "policy_decision"
          ],
          "properties": {
            "policy_decision": {
              "$ref": "#/definitions/PolicyDecision"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "operation_state"
          ],
          "properties": {
            "operation_state": {
              "$ref": "#/definitions/OperationState"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "side_effect_state"
          ],
          "properties": {
            "side_effect_state": {
              "$ref": "#/definitions/SideEffectState"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "simulated"
          ],
          "properties": {
            "simulated": {
              "type": "boolean"
            }
          }
        }
      ],
      "properties": {
        "event_kind": {
          "anyOf": [
            {
              "$ref": "#/definitions/StoryEventKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "operation_state": {
          "anyOf": [
            {
              "$ref": "#/definitions/OperationState"
            },
            {
              "type": "null"
            }
          ]
        },
        "policy_decision": {
          "anyOf": [
            {
              "$ref": "#/definitions/PolicyDecision"
            },
            {
              "type": "null"
            }
          ]
        },
        "provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "side_effect_state": {
          "anyOf": [
            {
              "$ref": "#/definitions/SideEffectState"
            },
            {
              "type": "null"
            }
          ]
        },
        "simulated": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "ResourceClaim": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "access",
            "classification",
            "kind",
            "path",
            "root"
          ],
          "properties": {
            "access": {
              "$ref": "#/definitions/FileAccess"
            },
            "classification": {
              "$ref": "#/definitions/DataClass"
            },
            "kind": {
              "type": "string",
              "enum": [
                "file"
              ]
            },
            "path": {
              "$ref": "#/definitions/WorkspaceRelativePath"
            },
            "root": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "classification",
            "kind",
            "method",
            "origin"
          ],
          "properties": {
            "classification": {
              "$ref": "#/definitions/DataClass"
            },
            "kind": {
              "type": "string",
              "enum": [
                "network"
              ]
            },
            "method": {
              "type": "string"
            },
            "origin": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "classification",
            "kind",
            "recipients"
          ],
          "properties": {
            "classification": {
              "$ref": "#/definitions/DataClass"
            },
            "kind": {
              "type": "string",
              "enum": [
                "email"
              ]
            },
            "recipients": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "access",
            "key",
            "kind",
            "namespace"
          ],
          "properties": {
            "access": {
              "$ref": "#/definitions/MemoryAccess"
            },
            "key": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "memory"
              ]
            },
            "namespace": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "limits",
            "network",
            "runtime",
            "workspace"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "code_execution"
              ]
            },
            "limits": {
              "$ref": "#/definitions/ExecutionLimits"
            },
            "network": {
              "$ref": "#/definitions/NetworkCapability"
            },
            "runtime": {
              "type": "string"
            },
            "workspace": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "classification",
            "content_hash",
            "kind",
            "source"
          ],
          "properties": {
            "classification": {
              "$ref": "#/definitions/DataClass"
            },
            "content_hash": {
              "$ref": "#/definitions/Sha256Digest"
            },
            "kind": {
              "type": "string",
              "enum": [
                "input_inspection"
              ]
            },
            "source": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "operation_id",
            "story_id"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "evidence"
              ]
            },
            "operation_id": {
              "$ref": "#/definitions/OperationId"
            },
            "story_id": {
              "$ref": "#/definitions/StoryId"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "format",
            "kind",
            "relative_path"
          ],
          "properties": {
            "format": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "artifact"
              ]
            },
            "relative_path": {
              "$ref": "#/definitions/WorkspaceRelativePath"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "provider",
            "redacted_summary"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "opaque_legacy"
              ]
            },
            "provider": {
              "type": "string"
            },
            "redacted_summary": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "RunMode": {
      "type": "string",
      "enum": [
        "live",
        "deterministic",
        "recorded"
      ]
    },
    "SafeArgumentView": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "path"
          ],
          "properties": {
            "content_hash": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Sha256Digest"
                },
                {
                  "type": "null"
                }
              ]
            },
            "kind": {
