{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "claims": {
      "items": {
        "properties": {
          "id": {
            "type": "string"
          },
          "obs_refs": {
            "items": {
              "pattern": "^obs_",
              "type": "string"
            },
            "type": "array"
          },
          "support": {
            "minProperties": 1,
            "properties": {
              "decision": {
                "type": "string"
              },
              "event_type": {
                "type": "string"
              },
              "execution_status": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              },
              "side_effect_executed": {
                "type": "boolean"
              }
            },
            "type": "object"
          },
          "text": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "text",
          "obs_refs"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "claims"
  ],
  "title": "ReportDraft",
  "type": "object"
}
