{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArtifactManifest",
  "type": "object",
  "required": [
    "artifacts",
    "schema_version"
  ],
  "properties": {
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ArtifactManifestEntry"
      }
    },
    "schema_version": {
      "type": "string"
    }
  },
  "definitions": {
    "ArtifactManifestEntry": {
      "type": "object",
      "required": [
