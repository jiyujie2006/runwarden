        "obs_refs",
        "relative_path"
      ],
      "properties": {
        "artifact_id": {
          "type": "string"
        },
        "obs_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "redaction_sidecar_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_sidecar_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "relative_path": {
          "type": "string"
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
